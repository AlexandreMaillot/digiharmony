    "conseilRappelPresentSousTexte": "The present moment won't come back. The feed will always be there.",
    "@conseilRappelPresentSousTexte": { "description": "ConseilsPage — conseilRappelPresent sub-text [PLACEHOLDER]" },
    "conseilRappelPresentDo1": "Put your phone down and notice what's around you",
