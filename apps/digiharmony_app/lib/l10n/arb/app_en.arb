    "conseilRappelLikesSousTexte": "Your worth has nothing to do with numbers online.",
    "@conseilRappelLikesSousTexte": { "description": "ConseilsPage — conseilRappelLikes sub-text [PLACEHOLDER]" },
    "conseilRappelLikesDo1": "Remind yourself that likes measure reach, not your value",
    "@conseilRappelLikesDo1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "conseilRappelLikesDo2": "Share what feels true to you, not what gets the most likes",
    "@conseilRappelLikesDo2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "conseilRappelLikesDo3": "Celebrate your real-life moments away from the screen",
    "@conseilRappelLikesDo3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "conseilRappelLikesDont1": "Don't measure your worth by how many likes you get",
    "@conseilRappelLikesDont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "conseilRappelLikesDont2": "Don't post just to get validation — your voice matters as it is",
    "@conseilRappelLikesDont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

