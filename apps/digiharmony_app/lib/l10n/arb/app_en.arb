    "tipDay01Do1": "Take a few deep breaths and notice how you feel",
    "@tipDay01Do1": { "description": "ConseilsPage — tipDay01 Do 1 [PLACEHOLDER — to be validated by Erasmus+ partners, DEC-CO-10]" },
    "tipDay01Do2": "Find a quiet spot and simply breathe for a minute",
    "@tipDay01Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay01Do3": "Be gentle with yourself when you feel stressed",
    "@tipDay01Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay01Dont1": "Don't push through without pausing to breathe",
    "@tipDay01Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay01Dont2": "Don't dismiss how your body feels right now",
    "@tipDay01Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay02Do1": "Drink a full glass of water when you feel low energy",
    "@tipDay02Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay02Do2": "Stretch your arms and shoulders gently for two minutes",
    "@tipDay02Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay02Do3": "Step away from your screen and move your body",
    "@tipDay02Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay02Dont1": "Don't ignore signs of tiredness — your body is speaking",
    "@tipDay02Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay02Dont2": "Don't stay still for hours without a small break",
    "@tipDay02Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay03Do1": "Write down one small thing that went well today",
    "@tipDay03Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay03Do2": "Notice something you appreciated, however small",
    "@tipDay03Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay03Do3": "Share your gratitude with someone you care about",
    "@tipDay03Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay03Dont1": "Don't force positivity — just notice what felt okay",
    "@tipDay03Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay03Dont2": "Don't compare your day to what others share online",
    "@tipDay03Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay04Do1": "Step outside, even for just five minutes",
    "@tipDay04Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay04Do2": "Look up at the sky and take a slow, deep breath",
    "@tipDay04Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay04Do3": "Leave your phone behind and enjoy the fresh air",
    "@tipDay04Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay04Dont1": "Don't scroll while you're outside — let yourself be present",
    "@tipDay04Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay04Dont2": "Don't rush — a short walk counts just as much",
    "@tipDay04Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay05Do1": "Put your phone in another room for a little while",
    "@tipDay05Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay05Do2": "Notice how it feels to have a moment of quiet",
    "@tipDay05Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay05Do3": "Use the silence to think, draw, or just rest",
    "@tipDay05Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay05Dont1": "Don't fill every quiet moment with a screen",
    "@tipDay05Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay05Dont2": "Don't feel the need to always be reachable",
    "@tipDay05Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay06Do1": "Smile at a friend, classmate, or someone you meet today",
    "@tipDay06Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay06Do2": "Say something kind — a small word can change someone's day",
    "@tipDay06Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay06Do3": "Let yourself feel the warmth of a genuine connection",
    "@tipDay06Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay06Dont1": "Don't replace real smiles with emoji-only conversations",
    "@tipDay06Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay06Dont2": "Don't underestimate how much a kind gesture matters",
    "@tipDay06Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "tipDay07Do1": "Speak to yourself the way you'd speak to a good friend",
    "@tipDay07Do1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay07Do2": "Acknowledge your efforts, even when things are hard",
    "@tipDay07Do2": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay07Do3": "Give yourself permission to have an imperfect day",
    "@tipDay07Do3": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay07Dont1": "Don't be harder on yourself than you'd be on others",
    "@tipDay07Dont1": { "description": "[PLACEHOLDER — DEC-CO-10]" },
    "tipDay07Dont2": "Don't wait to feel perfect before being kind to yourself",
    "@tipDay07Dont2": { "description": "[PLACEHOLDER — DEC-CO-10]" },

    "conseilRappelPresentCitation1": "Scroll later,",
