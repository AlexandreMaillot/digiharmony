<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements du target App Extension DeviceActivityReportExtension (SCAFFOLD).

  ⚠️  Ce fichier doit être câblé au TARGET d'extension dans Xcode
      (Build Settings > Code Signing Entitlements).

  L'entitlement family-controls est REQUIS à la fois sur le target hôte (Runner)
  ET sur le target d'extension. Les deux provisioning profiles doivent l'inclure.
  Voir README.md pour les étapes d'activation.
-->
<plist version="1.0">
<dict>
    <!-- Entitlement principal Screen Time / FamilyControls (accès spécial Apple) -->
    <key>com.apple.developer.family-controls</key>
    <true/>
</dict>
</plist>
